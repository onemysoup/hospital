# Django core
DJANGO_SECRET_KEY=replace-with-a-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database mode: sqlite or mysql
DB_ENGINE=sqlite

# SQLite
SQLITE_PATH=db.sqlite3

# MySQL (used when DB_ENGINE=mysql)
DB_NAME=hospital
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
